# ============================================
# GovTech National Unified Grievance Platform
# Environment Configuration Template
# ============================================

# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration (PostgreSQL for Production)
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=govtech_prod
DB_USER=govtech
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# For SQLite (Development Only)
# DB_DIALECT=sqlite
# DB_STORAGE=./govtech.sqlite

# Redis Configuration (for rate limiting, caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT Authentication
JWT_SECRET=CHANGE_ME_VERY_STRONG_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@govtech.gov.in

# SMS Configuration (for OTP)
SMS_PROVIDER=twilio
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_FROM_NUMBER=+1234567890

# AI/ML Configuration
AI_MODEL_VERSION=1.0
AI_CONFIDENCE_THRESHOLD=0.7

# SLA Configuration
SLA_CHECK_INTERVAL=*/15 * * * *
SLA_WARNING_HOURS=6

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Multi-Tenant
DEFAULT_TENANT_ID=1

# Admin Configuration
ADMIN_EMAIL=admin@govtech.gov.in
ADMIN_PHONE=9999999999

# Feature Flags
ENABLE_AI_CLASSIFICATION=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_SLA_PREDICTION=true
ENABLE_AUTO_ESCALATION=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true

# External APIs (if needed)
GOOGLE_MAPS_API_KEY=your-google-maps-key
WEATHER_API_KEY=your-weather-api-key

# Monitoring & Analytics
SENTRY_DSN=your-sentry-dsn
ANALYTICS_ID=your-analytics-id
